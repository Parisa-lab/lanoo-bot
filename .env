# ==================================================
# Telegram
# ==================================================

BOT_TOKEN=123456789:YOUR_TOKEN

# ==================================================
# Database
# ==================================================

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lanoo

# ==================================================
# Application
# ==================================================

ENVIRONMENT=development

DEBUG=true

# ==================================================
# Logging
# ==================================================

LOG_LEVEL=INFO

# ==================================================
# Network
# ==================================================

REQUEST_TIMEOUT=30

MAX_CONNECTIONS=20

# ==================================================
# Scraper
# ==================================================

SCRAPER_DELAY=1.0

# ==================================================
# Cache
# ==================================================

CACHE_TTL=300